# Required
DOMAIN=example.com

# Images (set by deploy script / GitHub Actions)
BACKEND_IMAGE=ghcr.io/OWNER/ark-backend:latest
FRONTEND_IMAGE=ghcr.io/OWNER/ark-frontend:latest

# Database
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://ark:change-me@db:5432/ark

# Optional: allow list for browser CORS (comma-separated).
# If frontend and backend are same-origin via Caddy, you can leave this empty.
# CORS_ALLOW_ORIGINS=https://example.com
CORS_ALLOW_ORIGINS=
